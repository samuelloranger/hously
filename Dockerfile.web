# Build stage (using Bun)
FROM oven/bun:latest AS builder

WORKDIR /app

# Copy workspace manifests first for better layer caching.
COPY bun.lock ./
COPY package.json ./
COPY apps/api/package.json ./apps/api/
COPY apps/shared/package.json ./apps/shared/
COPY apps/web/package.json ./apps/web/

# Copy Prisma schema so the API postinstall (prisma generate) succeeds.
COPY apps/api/prisma/schema.prisma ./apps/api/prisma/schema.prisma

# Install workspace dependencies from repo root.
RUN bun install --frozen-lockfile

# Copy parent tsconfig.json (required by apps/web/tsconfig.json)
COPY tsconfig.json ./

# Copy necessary source files and config
COPY apps/shared/ ./apps/shared/
COPY apps/web/ ./apps/web/

# Build React app
RUN cd apps/web && bun run build

# Final production stage (using a slim Bun image)
FROM oven/bun:slim

WORKDIR /app

# Copy built assets from builder stage
COPY --from=builder /app/apps/web/dist ./dist

# Install 'serve' globally to serve the static files without a full node_modules folder
RUN bun add -g serve

# Expose port 5173 (consistent with current setup)
EXPOSE 5173

# Serve the built application
CMD ["serve", "dist", "-p", "5173", "--single"]
