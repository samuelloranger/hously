{
  "name": "hously-monorepo",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "install:all": "bun install",
    "build": "bun run build:web",
    "build:web": "bun run --filter @hously/web build",
    "dev": "bun run --workspaces --if-present dev",
    "dev:api": "bun run --filter @hously/server dev",
    "dev:web": "bun run --filter @hously/web dev",
    "dev:services": "docker compose up db minio minio-init -d",
    "docker:down": "docker compose down",
    "docker:rebuild": "docker compose build --no-cache",
    "test": "bun run --filter @hously/web test && bun run --filter @hously/server test",
    "format": "bun run --workspaces --if-present format",
    "formatCheck": "bun run --workspaces format -- --check",
    "typecheck": "bun run --workspaces --if-present typecheck",
    "typecheck:build": "tsc -b tsconfig.build.json --pretty false",
    "lint": "bun run --workspaces --if-present lint",
    "knip": "knip",
    "clean": "rm -rf apps/web/dist node_modules apps/*/node_modules packages/*/node_modules && docker compose down -v",
    "db:migrate:dev": "bun run --filter @hously/server db:migrate:dev",
    "db:migrate:deploy": "bun run --filter @hously/server db:migrate",
    "db:migrate:push": "bun run --filter @hously/server db:push",
    "db:generate": "bun run --filter @hously/server db:generate",
    "db:studio": "bun run --filter @hously/server db:studio",
    "db:refresh-collation": "sh -c 'DB_NAME=${DB_NAME:-hously}; DB_USER=${DB_USER:-hously}; echo \"Refreshing template1 collation version...\"; docker compose exec -T db psql -U \"$DB_USER\" -d postgres -c \"ALTER DATABASE template1 REFRESH COLLATION VERSION;\"; echo \"Refreshing database collation version for database: $DB_NAME...\"; docker compose exec -T db psql -U \"$DB_USER\" -d postgres -c \"ALTER DATABASE $DB_NAME REFRESH COLLATION VERSION;\"; echo \"Done.\"'",
    "prepare": "husky"
  },
  "workspaces": [
    "apps/*"
  ],
  "devDependencies": {
    "@types/react": "~19.2.14",
    "elysia": "^1.4.28",
    "husky": "^9.1.7",
    "knip": "^6.1.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0",
    "@tanstack/react-query": "^5.96.0",
    "date-fns": "^4.1.0",
    "i18next": "^26.0.3",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-hook-form": "^7.72.0",
    "react-i18next": "^17.0.2",
    "sharp": "^0.34.5"
  },
  "version": "1.0.0"
}
