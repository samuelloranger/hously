# Build stage (using Bun)
FROM oven/bun:1.3.3

WORKDIR /app

# Prisma runtime requires OpenSSL in this image.
RUN apt-get update -y && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*

# Copy workspace manifests first for better cache use.
COPY bun.lock ./
COPY package.json ./
COPY apps/api/package.json ./apps/api/
COPY apps/app/package.json ./apps/app/
COPY apps/shared/package.json ./apps/shared/
COPY apps/web/package.json ./apps/web/

# Install workspace dependencies from repo root.
# Ignore lifecycle scripts; entrypoint handles prisma generate/migrations at runtime.
RUN bun install --frozen-lockfile --ignore-scripts

# Copy application source code
COPY apps/api ./apps/api
COPY apps/shared ./apps/shared

# Set working directory to the api application
WORKDIR /app/apps/api

# Expose the application port
EXPOSE 3000

# Make entrypoint executable
RUN chmod +x entrypoint.sh

# Run migrations then start the application
CMD ["./entrypoint.sh"]
