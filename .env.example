# =============================================================================
# Hously Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Lines marked [Required] must be set. Everything else has sensible defaults.

# -----------------------------------------------------------------------------
# Database [Required]
# -----------------------------------------------------------------------------
POSTGRES_DB=hously
POSTGRES_USER=hously
POSTGRES_PASSWORD=change-me
# Must match the credentials above. Use 'db' as hostname when running in Docker.
DATABASE_URL=postgresql://hously:change-me@db:5432/hously

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Option A: individual fields (used when REDIS_URL is not set)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=change-me
# Option B: full URL (takes precedence over individual fields)
# REDIS_URL=redis://:change-me@redis:6379/0

# -----------------------------------------------------------------------------
# MinIO / S3 Storage [Required for image uploads]
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me
S3_BUCKET_NAME=hously-images
S3_REGION=us-east-1
S3_USE_SSL=false

# -----------------------------------------------------------------------------
# App [Required]
# -----------------------------------------------------------------------------
SECRET_KEY=generate-a-random-secret-here
BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=production
TZ=America/New_York
LOG_LEVEL=DEBUG
API_PORT=3000

# -----------------------------------------------------------------------------
# Access Control [Required]
# -----------------------------------------------------------------------------
# Comma-separated lists. Only these emails can register or access admin features.
ALLOWED_EMAILS=your-email@example.com
ADMIN_EMAILS=your-email@example.com

# -----------------------------------------------------------------------------
# Web Push Notifications (VAPID)
# -----------------------------------------------------------------------------
# Required for browser push notifications. Generate keys with:
#
#   bunx web-push generate-vapid-keys
#
# This outputs a public key and a private key. Paste them below.
# Then create a vapid_keys/ directory and save them there as well,
# or just set these environment variables.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:your-email@example.com

# -----------------------------------------------------------------------------
# TMDB / OMDB (Optional - media discovery)
# -----------------------------------------------------------------------------
# Get a free TMDB API key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=
# Get a free OMDB API key at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# -----------------------------------------------------------------------------
# SMTP Email (Optional - invitations, password resets)
# -----------------------------------------------------------------------------
# Works with any SMTP server (AWS SES, Gmail, Mailgun, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=Hously

# -----------------------------------------------------------------------------
# Apple Push Notifications (Optional - iOS app)
# -----------------------------------------------------------------------------
APNS_TEAM_ID=
APNS_KEY_ID=
# Path to the .p8 key file (e.g., ./certs/AuthKey_XXXXXXX.p8) or raw key string
APNS_AUTH_KEY=
# Alternatively, certificate-based auth:
# APNS_CERT_PATH=./certs/aps.p12
# APNS_CERT_PASSPHRASE=
APNS_TOPIC=
APNS_PRODUCTION=false

# MediaInfo path remapping: translate arr-internal paths to the actual filesystem path
# Radarr/Sonarr usually store paths like /data/Movies/... but in your container
# they may be mounted at /mnt/storage/Movies/...
# MEDIA_PATH_FROM=/data
# MEDIA_PATH_TO=/mnt/storage
