# Database Configuration
POSTGRES_DB=hously
POSTGRES_USER=hously
POSTGRES_PASSWORD=hously_password
# DATABASE_URL for Docker (uses 'db' as hostname for the database service)
DATABASE_URL=postgresql://hously:hously_password@db:5432/hously

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# MinIO/S3 Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=hously-images
S3_REGION=us-east-1
S3_USE_SSL=false

# Timezone (used for date boundaries in cron jobs, habits, analytics, etc.)
TZ=America/New_York

# Flask Configuration
SECRET_KEY=dev-key-change-in-production
FLASK_ENV=development
FLASK_DEBUG=true
BASE_URL=http://localhost:5000
LOG_LEVEL=DEBUG
API_PORT=5000
CORS_ORIGIN=http://localhost:5173

# Access Control
# Comma-separated list of allowed email addresses
ALLOWED_EMAILS=your-email@example.com
# Comma-separated list of admin email addresses
ADMIN_EMAILS=your-email@example.com

# VAPID Keys (Optional - for web push notifications)
# Generate keys and place in vapid_keys/ directory, or set here:
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# TMDB API (Optional - dashboard upcoming releases)
TMDB_API_KEY=

# Apple Push Notification service (APNs)
APNS_TEAM_ID=
APNS_KEY_ID=
# Token-based auth: Path to the .p8 file (e.g., ./AuthKey_XXXXXXX.p8) OR the raw key string
APNS_AUTH_KEY=
# Certificate-based auth: Path to the .p12 file (e.g., ./certs/aps.p12)
APNS_CERT_PATH=
APNS_CERT_PASSPHRASE=
APNS_TOPIC=
APNS_PRODUCTION=false

# Gitea CI/CD (Optional - build status in sidebar)
GITEA_API_TOKEN=
GITEA_URL=https://git.example.com
GITEA_OWNER=samuelloranger
GITEA_REPO=hously

# SMTP Email (AWS SES or any SMTP server)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=Hously
