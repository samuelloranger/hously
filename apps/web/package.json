{
  "name": "@hously/web",
  "version": "1.0.0",
  "packageManager": "bun@1.3.11",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --project tsconfig.build.json --noEmit",
    "preview": "vite preview",
    "playwright:load": "bun scripts/playwright-load.mjs",
    "playwright:load:prod": "bun scripts/playwright-load.mjs",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "clean": "rm -rf dist node_modules",
    "generate-icons": "node scripts/generate-icons.js",
    "typecheck": "tsc --noEmit",
    "typecheck:native": "tsgo --noEmit",
    "format": "prettier --write \"{src,scripts}/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{ts,js,json,md}\""
  },
  "dependencies": {
    "@better-auth/passkey": "^1.6.9",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@fontsource/fira-code": "^5.2.7",
    "@hously/shared": "workspace:*",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-virtual": "^3.13.24",
    "@tanstack/router-plugin": "^1.167.35",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18n-iso-countries": "^7.14.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-image-crop": "^11.0.10",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.3.0",
    "happy-dom": "^20.9.0",
    "knip": "^6.12.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.14",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.10",
    "vite-plugin-compression2": "^2.5.3",
    "vitest": "^4.1.5"
  }
}
