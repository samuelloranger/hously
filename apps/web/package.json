    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.24",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "happy-dom": "^18.0.1",
    "knip": "^5.85.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0",
    "vite": "^8.0.0",
