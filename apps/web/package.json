{
  "name": "@hously/web",
  "version": "2.1.238",
  "packageManager": "bun@1.3.11",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --project tsconfig.build.json --noEmit && vite build",
    "preview": "vite preview",
    "playwright:load": "bun scripts/playwright-load.mjs",
    "playwright:load:prod": "BASE_URL=https://hously.example.com bun scripts/playwright-load.mjs",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "clean": "rm -rf dist node_modules",
    "generate-icons": "node scripts/generate-icons.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"{src,scripts}/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{ts,js,json,md}\""
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
