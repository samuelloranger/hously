{
  "name": "@hously/web",
  "version": "2.1.146",
  "packageManager": "bun@1.3.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --project tsconfig.build.json --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "clean": "rm -rf dist node_modules",
    "generate-icons": "node scripts/generate-icons.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"{src,scripts}/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{ts,js,json,md}\""
  },
