generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String    @id @default(uuid())
  name                    String    @default("")
  email                   String    @unique(map: "ix_users_email")
  emailVerified           Boolean   @default(false) @map("email_verified")
  passwordHash            String?   @map("password_hash")
  isAdmin                 Boolean?  @map("is_admin")
  lastLogin               DateTime? @map("last_login")
  createdAt               DateTime? @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  lastActivity            DateTime? @map("last_activity")
  firstName               String?   @map("first_name")
  lastName                String?   @map("last_name")
  locale                  String?
  avatarUrl               String?   @map("avatar_url")
  dashboardConfig         Json?     @map("dashboard_config")
  calendarToken           String?   @unique(map: "ix_users_calendar_token") @map("calendar_token")

  notifications        Notification[]
  customEvents         CustomEvent[]
  reminders            Reminder[]
  userSubscriptions    UserSubscription[]
  taskCompletions      TaskCompletion[]
  activityLogs         ActivityLog[]
  choresAdded          Chore[]               @relation("ChoreAddedBy")
  choresAssigned       Chore[]               @relation("ChoreAssignedTo")
  choresCompleted      Chore[]               @relation("ChoreCompletedBy")
  notificationChannels NotificationChannel[]
  habits               Habit[]
  invitationsSent      Invitation[]          @relation("InvitationInviter")
  watchlistItems       WatchlistItem[]
  createdBoardTasks    BoardTask[]           @relation("BoardTaskCreatedBy")
  assignedBoardTasks   BoardTask[]           @relation("BoardTaskAssignee")
  boardTaskActivities  BoardTaskActivity[]
  boardTimeLogs        BoardTimeLog[]
  baSessions           BaSession[]
  baAccounts           BaAccount[]
  baPasskeys           BaPasskey[]

  @@map("users")
}

enum BoardTaskStatus {
  BACKLOG
  ON_HOLD
  TODO
  IN_PROGRESS
  DONE
}

enum BoardTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model BoardTask {
  id               Int               @id @default(autoincrement())
  title            String
  description      String?
  status           BoardTaskStatus
  position         Int
  priority         BoardTaskPriority @default(MEDIUM)
  startDate        DateTime?         @map("start_date") @db.Date
  dueDate          DateTime?         @map("due_date") @db.Date
  assigneeId       String?           @map("assignee_id")
  tags             String[]
  createdBy        String            @map("created_by")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  estimatedMinutes Int?              @map("estimated_minutes")
  loggedMinutes    Int               @default(0) @map("logged_minutes")
  archived         Boolean           @default(false) @map("archived")

  createdByUser        User                  @relation("BoardTaskCreatedBy", fields: [createdBy], references: [id], onDelete: Cascade)
  assignee             User?                 @relation("BoardTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  boardTags            BoardTag[]            @relation("BoardTaskTags")
  activities           BoardTaskActivity[]
  blockingDependencies BoardTaskDependency[] @relation("BlockingTask")
  blockedDependencies  BoardTaskDependency[] @relation("BlockedTask")
  timeLogs             BoardTimeLog[]

  @@index([status, position], map: "ix_board_tasks_status_position")
  @@map("board_tasks")
}

model BoardTimeLog {
  id       Int      @id @default(autoincrement())
  taskId   Int      @map("task_id")
  userId   String   @map("user_id")
  minutes  Int
  note     String?
  loggedAt DateTime @default(now()) @map("logged_at")

  task BoardTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId], map: "ix_board_time_logs_task_id")
  @@map("board_time_logs")
}

model BoardTaskDependency {
  id             Int      @id @default(autoincrement())
  blockingTaskId Int      @map("blocking_task_id")
  blockedTaskId  Int      @map("blocked_task_id")
  createdAt      DateTime @default(now()) @map("created_at")

  blockingTask BoardTask @relation("BlockingTask", fields: [blockingTaskId], references: [id], onDelete: Cascade)
  blockedTask  BoardTask @relation("BlockedTask", fields: [blockedTaskId], references: [id], onDelete: Cascade)

  @@unique([blockingTaskId, blockedTaskId], map: "uq_board_task_dependency")
  @@index([blockedTaskId], map: "ix_board_task_dependency_blocked")
  @@map("board_task_dependencies")
}

model BoardTag {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  color     String?
  createdAt DateTime @default(now()) @map("created_at")

  tasks BoardTask[] @relation("BoardTaskTags")

  @@map("board_tags")
}

enum BoardTaskActivityType {
  created
  comment
  status_change
  priority_change
  assignee_change
  archived
  unarchived
}

model BoardTaskActivity {
  id        Int                   @id @default(autoincrement())
  taskId    Int                   @map("task_id")
  userId    String                @map("user_id")
  type      BoardTaskActivityType
  body      String?
  metadata  Json?
  createdAt DateTime              @default(now()) @map("created_at")

  task BoardTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt], map: "ix_board_task_activities_task_created")
  @@map("board_task_activities")
}

model Notification {
  id                   Int       @id @default(autoincrement())
  userId               String    @map("user_id")
  title                String
  body                 String
  type                 String
  read                 Boolean   @default(false)
  readAt               DateTime? @map("read_at")
  url                  String?
  notificationMetadata Json?     @map("notification_metadata")
  createdAt            DateTime  @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt], map: "ix_notifications_created_at")
  @@index([userId], map: "ix_notifications_user_id")
  @@map("notifications")
}

model NotificationTemplate {
  id            Int       @id @default(autoincrement())
  serviceId     Int       @map("service_id")
  eventType     String    @map("event_type")
  language      String    @default("en")
  titleTemplate String    @map("title_template")
  bodyTemplate  String    @map("body_template")
  enabled       Boolean   @default(true)
  createdAt     DateTime? @map("created_at")
  updatedAt     DateTime? @map("updated_at")

  service ExternalNotificationService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([eventType], map: "ix_notification_templates_event_type")
  @@index([language], map: "ix_notification_templates_language")
  @@index([serviceId], map: "ix_notification_templates_service_id")
  @@map("notification_templates")
}

model ExternalNotificationService {
  id               Int       @id @default(autoincrement())
  serviceName      String    @unique(map: "ix_external_notification_services_service_name") @map("service_name")
  enabled          Boolean   @default(false)
  token            String?   @unique(map: "ix_external_notification_services_token")
  createdAt        DateTime? @map("created_at")
  updatedAt        DateTime? @map("updated_at")
  notifyAdminsOnly Boolean   @default(true) @map("notify_admins_only")

  templates NotificationTemplate[]
  logs      ExternalNotificationServiceLog[]

  @@map("external_notification_services")
}

model ExternalNotificationServiceLog {
  id        Int       @id @default(autoincrement())
  serviceId Int       @map("service_id")
  eventType String    @map("event_type")
  payload   String
  createdAt DateTime? @map("created_at")
  status    String    @db.VarChar(20)

  service ExternalNotificationService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId], map: "ix_external_notification_service_logs_service_id")
  @@map("external_notification_service_logs")
}

model Integration {
  id        Int       @id @default(autoincrement())
  type      String    @unique(map: "ix_integrations_type")
  enabled   Boolean   @default(false)
  config    Json?
  createdAt DateTime? @map("created_at")
  updatedAt DateTime? @map("updated_at")

  @@map("integrations")
}

model OidcProvider {
  id           String   @id @default(uuid())
  slug         String   @unique
  name         String
  discoveryUrl String   @map("discovery_url")
  clientId     String   @map("client_id")
  clientSecret String   @map("client_secret")
  enabled      Boolean  @default(true)
  iconUrl      String?  @map("icon_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("oidc_providers")
}

model CustomEvent {
  id                          Int       @id @default(autoincrement())
  title                       String
  description                 String?
  startDatetime               DateTime  @map("start_datetime")
  endDatetime                 DateTime  @map("end_datetime")
  allDay                      Boolean?  @map("all_day")
  color                       String
  userId                      String    @map("user_id")
  recurrenceType              String?   @map("recurrence_type")
  recurrenceIntervalDays      Int?      @map("recurrence_interval_days")
  recurrenceOriginalCreatedAt DateTime? @map("recurrence_original_created_at")
  createdAt                   DateTime? @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("custom_events")
}

model Reminder {
  id                   Int       @id @default(autoincrement())
  choreId              Int       @map("chore_id")
  reminderDatetime     DateTime  @map("reminder_datetime")
  userId               String    @map("user_id")
  active               Boolean?
  lastNotificationSent DateTime? @map("last_notification_sent")
  createdAt            DateTime? @map("created_at")

  chore Chore @relation(fields: [choreId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@map("reminders")
}

model UserSubscription {
  id               Int       @id @default(autoincrement())
  userId           String    @map("user_id")
  subscriptionInfo String    @map("subscription_info")
  endpoint         String?
  createdAt        DateTime? @map("created_at")
  updatedAt        DateTime? @map("updated_at")
  deviceName       String?   @map("device_name")
  osName           String?   @map("os_name")
  osVersion        String?   @map("os_version")
  browserName      String?   @map("browser_name")
  browserVersion   String?   @map("browser_version")
  platform         String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([endpoint], map: "ix_user_subscriptions_endpoint")
  @@index([userId], map: "ix_user_subscriptions_user_id")
  @@map("user_subscriptions")
}

model TaskCompletion {
  id          Int      @id @default(autoincrement())
  userId      String   @map("user_id")
  taskType    String   @map("task_type") @db.VarChar(50)
  taskId      Int      @map("task_id")
  completedAt DateTime @map("completed_at")
  taskName    String   @map("task_name") @db.VarChar(255)
  emotion     String?  @db.VarChar(10)

  user User @relation(fields: [userId], references: [id])

  @@map("task_completions")
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  type      String   @db.VarChar(50)
  userId    String?  @map("user_id")
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt], map: "ix_activity_logs_created_at")
  @@index([type], map: "ix_activity_logs_type")
  @@index([userId], map: "ix_activity_logs_user_id")
  @@map("activity_logs")
}

model Chore {
  id                          Int       @id @default(autoincrement())
  choreName                   String    @map("chore_name")
  description                 String?
  assignedTo                  String?   @map("assigned_to")
  completed                   Boolean?
  addedBy                     String    @map("added_by")
  completedBy                 String?   @map("completed_by")
  reminderEnabled             Boolean?  @map("reminder_enabled")
  createdAt                   DateTime? @map("created_at")
  completedAt                 DateTime? @map("completed_at")
  imagePath                   String?   @map("image_path")
  recurrenceType              String?   @map("recurrence_type")
  recurrenceIntervalDays      Int?      @map("recurrence_interval_days")
  recurrenceWeekday           Int?      @map("recurrence_weekday")
  recurrenceOriginalCreatedAt DateTime? @map("recurrence_original_created_at")
  recurrenceParentId          Int?      @map("recurrence_parent_id")
  position                    Int

  addedByUser      User       @relation("ChoreAddedBy", fields: [addedBy], references: [id])
  assignedToUser   User?      @relation("ChoreAssignedTo", fields: [assignedTo], references: [id])
  completedByUser  User?      @relation("ChoreCompletedBy", fields: [completedBy], references: [id])
  recurrenceParent Chore?     @relation("ChoreRecurrence", fields: [recurrenceParentId], references: [id], onDelete: SetNull)
  childChores      Chore[]    @relation("ChoreRecurrence")
  reminders        Reminder[]

  @@map("chores")
}

model Invitation {
  id         Int       @id @default(autoincrement())
  email      String
  token      String    @unique(map: "ix_invitations_token")
  status     String    @default("pending") @db.VarChar(20)
  expiresAt  DateTime  @map("expires_at")
  invitedBy  String    @map("invited_by")
  locale     String    @default("en")
  isAdmin    Boolean   @default(false) @map("is_admin")
  createdAt  DateTime  @default(now()) @map("created_at")
  acceptedAt DateTime? @map("accepted_at")

  inviter User @relation("InvitationInviter", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([email], map: "ix_invitations_email")
  @@map("invitations")
}

model NotificationChannel {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  type      String   @db.VarChar(20)
  label     String   @db.VarChar(100)
  config    Json
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "ix_notification_channels_user_id")
  @@map("notification_channels")
}

model Habit {
  id          Int       @id @default(autoincrement())
  userId      String    @map("user_id")
  name        String
  emoji       String
  description String?
  timesPerDay Int       @default(1) @map("times_per_day")
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @map("updated_at")

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules   HabitSchedule[]
  completions HabitCompletion[]

  @@index([userId], map: "ix_habits_user_id")
  @@map("habits")
}

enum HabitCompletionStatus {
  done
  skipped
}

model HabitSchedule {
  id                   Int       @id @default(autoincrement())
  habitId              Int       @map("habit_id")
  time                 String // "HH:mm" format (e.g. "08:00", "14:30")
  lastNotificationSent DateTime? @map("last_notification_sent")

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@index([habitId], map: "ix_habit_schedules_habit_id")
  @@map("habit_schedules")
}

model HabitCompletion {
  id          Int                   @id @default(autoincrement())
  habitId     Int                   @map("habit_id")
  date        DateTime // Date-only (start of day UTC) for grouping
  completedAt DateTime              @default(now()) @map("completed_at")
  status      HabitCompletionStatus @default(done)

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@index([habitId, date], map: "ix_habit_completions_habit_date")
  @@map("habit_completions")
}

model QbittorrentRequestLog {
  id            Int      @id @default(autoincrement())
  method        String   @db.VarChar(10)
  endpoint      String   @db.VarChar(255)
  requestPath   String   @map("request_path") @db.VarChar(512)
  statusCode    Int?     @map("status_code")
  ok            Boolean  @default(false)
  durationMs    Int      @map("duration_ms")
  responseBytes Int?     @map("response_bytes")
  authRetried   Boolean  @default(false) @map("auth_retried")
  rid           Int?
  fullUpdate    Boolean? @map("full_update")
  itemCount     Int?     @map("item_count")
  removedCount  Int?     @map("removed_count")
  errorMessage  String?  @map("error_message") @db.Text
  meta          Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([createdAt], map: "ix_qbittorrent_request_logs_created_at")
  @@index([endpoint, createdAt], map: "ix_qbittorrent_request_logs_endpoint_created_at")
  @@index([ok, createdAt], map: "ix_qbittorrent_request_logs_ok_created_at")
  @@map("qbittorrent_request_logs")
}

model WatchlistItem {
  id          Int      @id @default(autoincrement())
  userId      String   @map("user_id")
  tmdbId      Int      @map("tmdb_id")
  mediaType   String   @map("media_type")
  title       String
  posterUrl   String?  @map("poster_url")
  overview    String?
  releaseYear Int?     @map("release_year")
  voteAverage Float?   @map("vote_average")
  addedAt     DateTime @default(now()) @map("added_at")

  /// Cached TMDB theatrical release date (movies only). Used for day-before reminders.
  movieReleaseDate       DateTime? @map("movie_release_date") @db.Date
  /// YYYY-MM-DD release date we already sent a day-before reminder for (movies only).
  releaseReminderSentFor String?   @map("release_reminder_sent_for") @db.VarChar(10)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, tmdbId, mediaType], map: "uq_watchlist_user_tmdb_type")
  @@index([userId, addedAt], map: "ix_watchlist_user_added_at")
  @@map("watchlist_items")
}

model QualityProfile {
  id                       Int      @id @default(autoincrement())
  name                     String   @unique
  minResolution            Int      @default(1080) @map("min_resolution") // 480 | 720 | 1080 | 2160
  preferredSources         String[] @map("preferred_sources")
  preferredCodecs          String[] @map("preferred_codecs")
  preferredLanguages       String[] @default([]) @map("preferred_languages")
  prioritizedTrackers      String[] @default([]) @map("prioritized_trackers")
  preferTrackerOverQuality Boolean  @default(false) @map("prefer_tracker_over_quality")
  maxSizeGb                Float?   @map("max_size_gb")
  requireHdr               Boolean  @default(false) @map("require_hdr")
  preferHdr                Boolean  @default(false) @map("prefer_hdr")
  cutoffResolution         Int?     @map("cutoff_resolution")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  media              LibraryMedia[]
  defaultForSettings MediaSettings[] @relation("DefaultQualityProfile")

  @@map("quality_profiles")
}

model BaSession {
  id        String   @id @default(uuid())
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  providerId String?  @map("provider_id")
  userId     String   @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "ix_ba_sessions_user_id")
  @@map("ba_sessions")
}

model BaAccount {
  id                    String    @id @default(uuid())
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  idToken               String?   @map("id_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?   @db.Text
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "ix_ba_accounts_user_id")
  @@map("ba_accounts")
}

model BaVerification {
  id         String   @id @default(uuid())
  identifier String
  value      String   @db.Text
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("ba_verifications")
}

model BaPasskey {
  id           String    @id @default(uuid())
  name         String?
  publicKey    String    @map("public_key") @db.Text
  userId       String    @map("user_id")
  credentialID String    @map("credential_id")
  counter      Int
  deviceType   String    @map("device_type")
  backedUp     Boolean   @map("backed_up")
  transports   String?
  createdAt    DateTime? @map("created_at")
  aaguid       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([credentialID], map: "ix_ba_passkeys_credential_id")
  @@index([userId], map: "ix_ba_passkeys_user_id")
  @@map("ba_passkeys")
}

model LibraryMedia {
  id                    Int       @id @default(autoincrement())
  tmdbId                Int       @unique @map("tmdb_id")
  type                  String // "movie" | "show"
  title                 String
  sortTitle             String?   @map("sort_title")
  year                  Int?
  status                String    @default("wanted") // wanted | downloading | downloaded | skipped | returning | in_production | planned | upgrading
  tmdbStatus            String?   @map("tmdb_status")
  tmdbStatusRefreshedAt DateTime? @map("tmdb_status_refreshed_at")
  monitored             Boolean   @default(true)
  posterUrl             String?   @map("poster_url")
  overview              String?
  digitalReleaseDate    DateTime? @map("digital_release_date")
  qualityProfileId      Int?      @map("quality_profile_id")
  searchAttempts        Int       @default(0) @map("search_attempts")
  addedAt               DateTime  @default(now()) @map("added_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  qualityProfile    QualityProfile?   @relation(fields: [qualityProfileId], references: [id], onDelete: SetNull)
  episodes          LibraryEpisode[]
  files             MediaFile[]       @relation("MediaFileMedia")
  downloadHistories DownloadHistory[]
  blocklistEntries  GrabBlocklist[]
  attentionAlerts   LibraryAttentionAlert[]

  @@index([type], map: "ix_library_media_type")
  @@index([status], map: "ix_library_media_status")
  @@index([qualityProfileId], map: "ix_library_media_quality_profile_id")
  @@map("library_media")
}

model LibraryEpisode {
  id             Int       @id @default(autoincrement())
  mediaId        Int       @map("media_id")
  season         Int
  episode        Int
  title          String?
  airDate        DateTime? @map("air_date") @db.Date
  status         String    @default("wanted") // wanted | downloading | downloaded | skipped | upgrading
  monitored      Boolean   @default(true)
  tmdbEpisodeId  Int?      @map("tmdb_episode_id")
  downloadedAt   DateTime? @map("downloaded_at")
  searchAttempts Int       @default(0) @map("search_attempts")

  media             LibraryMedia      @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  files             MediaFile[]       @relation("MediaFileEpisode")
  downloadHistories DownloadHistory[]
  blocklistEntries  GrabBlocklist[]
  attentionAlerts   LibraryAttentionAlert[]

  @@unique([mediaId, season, episode])
  @@index([mediaId], map: "ix_library_episodes_media_id")
  @@map("library_episodes")
}

model DownloadHistory {
  id                         Int       @id @default(autoincrement())
  mediaId                    Int?      @map("media_id")
  episodeId                  Int?      @map("episode_id")
  releaseTitle               String    @map("release_title")
  indexer                    String?
  torrentHash                String?   @map("torrent_hash")
  downloadUrl                String?   @map("download_url")
  qualityParsed              Json?     @map("quality_parsed")
  grabbedAt                  DateTime  @default(now()) @map("grabbed_at")
  completedAt                DateTime? @map("completed_at")
  failed                     Boolean   @default(false)
  failReason                 String?   @map("fail_reason")
  isUpgrade                  Boolean   @default(false) @map("is_upgrade")
  /// Set when post-processing fails after the torrent completed
  postProcessError           String?   @map("post_process_error") @db.Text
  /// Final library path after successful post-processing
  postProcessDestinationPath String?   @map("post_process_destination_path") @db.Text

  media   LibraryMedia?   @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  episode LibraryEpisode? @relation(fields: [episodeId], references: [id], onDelete: SetNull)

  @@index([torrentHash], map: "ix_download_history_torrent_hash")
  @@index([mediaId], map: "ix_download_history_media_id")
  @@map("download_history")
}

/// Open alerts are created by hourly cron from library grab/download conditions; one open row per (media, scope, kind).
model LibraryAttentionAlert {
  id                    Int       @id @default(autoincrement())
  mediaId               Int       @map("media_id")
  /// Target episode when scope_type = episode; null for movie or season_pack
  episodeId             Int?      @map("episode_id")
  /// TV season when scope_type = season_pack; optional mirror for episode scope
  season                Int?
  scopeType             String    @map("scope_type") // movie | episode | season_pack
  kind                  String // LibraryAttentionKind
  status                String    @default("open") // open | dismissed | resolved_auto
  detail                String?   @db.Text
  downloadHistoryId     Int?      @map("download_history_id")
  searchAttempts        Int?      @map("search_attempts")
  grabbedAt             DateTime? @map("grabbed_at")
  libraryStatusSnapshot String?   @map("library_status_snapshot")
  dismissedAt           DateTime? @map("dismissed_at")
  resolvedAt            DateTime? @map("resolved_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  media   LibraryMedia    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  episode LibraryEpisode? @relation(fields: [episodeId], references: [id], onDelete: SetNull)

  @@index([mediaId], map: "ix_library_attention_alert_media_id")
  @@index([status], map: "ix_library_attention_alert_status")
  @@map("library_attention_alerts")
}

model GrabBlocklist {
  id           Int      @id @default(autoincrement())
  torrentHash  String?  @map("torrent_hash")
  releaseTitle String   @map("release_title")
  indexer      String?
  mediaId      Int?     @map("media_id")
  episodeId    Int?     @map("episode_id")
  reason       String?
  blockedAt    DateTime @default(now()) @map("blocked_at")

  media   LibraryMedia?   @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  episode LibraryEpisode? @relation(fields: [episodeId], references: [id], onDelete: SetNull)

  @@index([torrentHash], map: "ix_grab_blocklist_hash")
  @@index([mediaId], map: "ix_grab_blocklist_media_id")
  @@map("grab_blocklist")
}

/// Singleton media / library post-processing settings (row id = 1)
model MediaSettings {
  id                      Int      @id @default(1)
  moviesLibraryPath       String?  @map("movies_library_path")
  showsLibraryPath        String?  @map("shows_library_path")
  fileOperation           String   @default("hardlink") @map("file_operation")
  movieTemplate           String   @default("{title} ({year}) [{resolution} {source}]") @map("movie_template")
  episodeTemplate         String   @default("{show}/Season {season}/{show} - S{season:02}E{episode:02} - {title} [{resolution} {source}]") @map("episode_template")
  minSeedRatio            Float    @default(1) @map("min_seed_ratio")
  postProcessingEnabled   Boolean  @default(false) @map("post_processing_enabled")
  defaultQualityProfileId Int?     @map("default_quality_profile_id")
  activeIndexerManager    String?  @map("active_indexer_manager")
  updatedAt               DateTime @updatedAt @map("updated_at")

  defaultQualityProfile QualityProfile? @relation("DefaultQualityProfile", fields: [defaultQualityProfileId], references: [id], onDelete: SetNull)

  @@map("media_settings")
}

/// Singleton app-wide settings (row id = 1)
model AppSettings {
  id                         Int      @id @default(1)
  countryCode                String   @default("US") @map("country_code") @db.VarChar(2)
  calendarSubdivisionCode    String?  @map("calendar_subdivision_code") @db.VarChar(16)
  upcomingWindowMonths       Int      @default(12) @map("upcoming_window_months")
  upcomingLanguages          String   @default("en,fr") @map("upcoming_languages")
  dashboardWidgetVisibility  Json     @default("{\"weather\":true,\"homeassistant\":true,\"system\":true,\"downloads\":true,\"rss\":true}") @map("dashboard_widget_visibility")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model MediaFile {
  id             Int      @id @default(autoincrement())
  mediaId        Int?     @map("media_id")
  episodeId      Int?     @map("episode_id")
  filePath       String   @map("file_path")
  fileName       String   @map("file_name")
  sizeBytes      BigInt   @map("size_bytes")
  durationSecs   Float?   @map("duration_secs")
  releaseGroup   String?  @map("release_group")
  videoCodec     String?  @map("video_codec")
  videoProfile   String?  @map("video_profile")
  width          Int?
  height         Int?
  frameRate      Float?   @map("frame_rate")
  bitDepth       Int?     @map("bit_depth")
  videoBitrate   Int?     @map("video_bitrate")
  hdrFormat      String?  @map("hdr_format")
  resolution     Int?
  source         String?
  audioFormat    String?  @map("audio_format")
  isProper       Boolean  @default(false) @map("is_proper")
  audioTracks    Json     @default("[]") @map("audio_tracks")
  subtitleTracks Json     @default("[]") @map("subtitle_tracks")
  languageTags   String[] @default([]) @map("language_tags")
  scannedAt      DateTime @default(now()) @map("scanned_at")

  media   LibraryMedia?   @relation("MediaFileMedia", fields: [mediaId], references: [id], onDelete: Cascade)
  episode LibraryEpisode? @relation("MediaFileEpisode", fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([mediaId], map: "ix_media_files_media_id")
  @@index([episodeId], map: "ix_media_files_episode_id")
  @@index([languageTags], map: "ix_media_files_language_tags", type: Gin)
  @@map("media_files")
}

model LibraryHealthLog {
  id          Int      @id @default(autoincrement())
  status      String
  trigger     String   @default("manual")
  startedAt   DateTime @default(now()) @map("started_at")
  completedAt DateTime @map("completed_at")
  durationMs  Int      @map("duration_ms")
  summary     Json
  issues      Json
  warnings    String[] @default([])
  error       String?  @db.Text

  @@index([startedAt], map: "ix_library_health_log_started_at")
  @@map("library_health_log")
}

model MinecraftServer {
  id                    Int       @id @default(autoincrement())
  name                  String
  host                  String
  port                  Int       @default(25565)
  pollIntervalMinutes   Int       @default(5)          @map("poll_interval_minutes")
  enabled               Boolean   @default(true)
  widgetView            String    @default("compact")  @map("widget_view")

  isOnline              Boolean   @default(false)      @map("is_online")
  onlinePlayers         Int?                           @map("online_players")
  maxPlayers            Int?                           @map("max_players")
  version               String?
  motd                  String?   @db.Text
  latencyMs             Int?                           @map("latency_ms")
  favicon               String?   @db.Text
  playerSample          Json?                          @map("player_sample")

  lastCheckedAt         DateTime?                      @map("last_checked_at")
  lastStatusChangeAt    DateTime?                      @map("last_status_change_at")

  createdAt             DateTime? @default(now())      @map("created_at")
  updatedAt             DateTime? @updatedAt           @map("updated_at")

  @@map("minecraft_servers")
}
