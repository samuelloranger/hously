{
  "name": "@hously/server",
  "version": "2.0.265",
  "packageManager": "bun@1.3.3",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env --watch src/index.ts",
    "test": "bun test",
    "db:generate": "set -a && . ../../.env && set +a && bunx prisma generate",
    "db:migrate:dev": "set -a && . ../../.env && set +a && bunx prisma migrate dev",
    "db:migrate": "set -a && . ../../.env && set +a && bunx prisma migrate deploy",
    "db:push": "set -a && . ../../.env && set +a && bunx prisma db push",
    "db:studio": "set -a && . ../../.env && set +a && bunx prisma studio",
    "postinstall": "prisma generate",
    "format": "prettier --write \"{src,prisma}/**/*.{ts,js,json,md}\" \"*.{ts,js,json,md}\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/cron": "^1.4.1",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/swagger": "latest",
    "@hously/shared": "workspace:*",
    "@parse/node-apn": "^7.1.0",
    "@prisma/client": "6.19.0",
    "@react-email/components": "^1.0.8",
    "@react-email/render": "^2.0.4",
    "@react-email/tailwind": "^2.0.5",
    "elysia": "latest",
    "elysia-rate-limit": "^4.5.0",
    "node-html-parser": "^7.0.2",
    "nodemailer": "^8.0.1",
    "uuid": "^11.1.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/apn": "^2.1.6",
    "@types/nodemailer": "^7.0.11",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "bun-types": "latest",
    "prisma": "6.19.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
