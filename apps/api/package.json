{
  "name": "@hously/server",
  "version": "1.0.0",
  "packageManager": "bun@1.3.3",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env --watch src/index.ts",
    "test": "bun test",
    "db:generate": "set -a && . ../../.env && set +a && bunx prisma generate",
    "db:migrate:dev": "set -a && . ../../.env && set +a && bunx prisma migrate dev",
    "db:migrate": "set -a && . ../../.env && set +a && bunx prisma migrate deploy",
    "db:push": "set -a && . ../../.env && set +a && bunx prisma db push",
    "db:studio": "set -a && . ../../.env && set +a && bunx prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/cron": "^1.4.1",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/swagger": "latest",
    "@prisma/client": "6.19.0",
    "elysia": "latest",
    "elysia-rate-limit": "^4.4.2",
    "expo-server-sdk": "^5.0.0",
    "sharp": "^0.33.5",
    "uuid": "^11.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "bun-types": "latest",
    "prisma": "6.19.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
