{
  "name": "@hously/server",
  "version": "2.3.2",
  "packageManager": "bun@1.3.11",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env --watch src/index.ts",
    "test": "bun test",
    "db:generate": "set -a && . ../../.env && set +a && bunx prisma generate",
    "db:migrate:dev": "set -a && . ../../.env && set +a && bunx prisma migrate dev && bunx prisma generate",
    "db:migrate": "set -a && . ../../.env && set +a && bunx prisma migrate deploy",
    "db:push": "set -a && . ../../.env && set +a && bunx prisma db push && bunx prisma generate",
    "db:studio": "set -a && . ../../.env && set +a && bunx prisma studio",
    "qbittorrent:client-debug": "bun src/scripts/qbittorrentClientDebug.ts",
    "qbittorrent:request-logs": "bun src/scripts/qbittorrentRequestLogs.ts",
    "postinstall": "prisma generate",
    "format": "prettier --write \"{src,prisma}/**/*.{ts,js,json,md}\" \"*.{ts,js,json,md}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1020.0",
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/static": "^1.4.7",
    "@elysiajs/swagger": "^1.3.1",
    "@hously/shared": "workspace:*",
    "@parse/node-apn": "^8.0.0",
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "7.6.0",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "@react-email/tailwind": "^2.0.6",
    "bullmq": "^5.71.1",
    "elysia": "^1.4.28",
    "elysia-rate-limit": "^4.5.1",
    "ioredis": "^5.10.1",
    "node-html-parser": "^7.1.0",
    "nodemailer": "^8.0.4",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.11",
    "@types/web-push": "^3.6.4",
    "bun-types": "^1.3.11",
    "prisma": "7.6.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
