{
  "name": "@hously/server",
  "version": "1.0.0",
  "packageManager": "bun@1.3.3",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio --host localhost --port 3001 --verbose --config drizzle.config.ts",
    "db:introspect": "drizzle-kit introspect"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/cron": "^1.4.1",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/swagger": "latest",
    "drizzle-orm": "^0.45.1",
    "elysia": "latest",
    "elysia-rate-limit": "^4.4.2",
    "pg": "^8.17.2",
    "sharp": "^0.33.5",
    "uuid": "^11.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.8"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
